%% ============================================================================
%% research skill — FSM (edge-for-edge with ResearchPlaybook / ResearchMachine)
%% apps/orchestration/src/orchestration/playbooks/research.py
%% ============================================================================
%% One machine serves all three modes (quick / standard / deep). The mode is
%% caller-declared (constraints.mode) or MODEL-declared by piper in its plan
%% SUMMARY (the keyword detect_mode router was deleted); only an explicit caller
%% quick takes the single-agent fast-path. State lives in the durable SQLite
%% checkpointer keyed by run_id.
%%
%% READING NOTES:
%%   * Multiple guarded arrows from ONE state are MUTUALLY EXCLUSIVE (XOR).
%%   * [quick]/[standard]/[deep] on an edge = a mode guard.
%%   * Both critique loops AND the validation loop are BOUNDED by ctx.max_iterations;
%%     on exhaustion the run proceeds honestly with a recorded warning (never
%%     force-approves / never ships unverified claims as verified).
%%   * researching is a DYNAMIC FAN (arrangement 4): route_after('planning') emits
%%     one read-only echo branch per sub-query into ctx.extras['dynamic_branches'],
%%     bounded by constraints.max_fan_width (default 8); the explicit-quick
%%     fast-path stays a single echo agent via the primitive fallback.
%%   * critiquing_* (carren) and validating (vera) are EVIDENCE-GATED (Rec 4): the
%%     contract rejects a verdict with no captured evidence.
%%   * validating (vera) is an independent citation-grounding gate that runs in ALL
%%     modes before report_writing; a FAIL loops back to synthesizing to re-ground.
%%   * to_unknown fires when progress_check returns a reason (needs_clarification,
%%     *_complete=false, a stalled critique, or a stalled validation); it is
%%     available only from the ESCALATABLE_STATES (report_writing does NOT escalate).
%% ============================================================================
stateDiagram-v2
    [*] --> intake

    %% intake: caller mode or planning-for-model-to-declare; empty goal aborts.
    intake --> planning : start_plan\n[default: mode caller- or model-declared]
    intake --> researching : start_research\n[explicit constraints.mode == quick]

    %% planning (piper) — decompose into sub-queries; deep adds a critique gate
    planning --> critiquing_plan : plan_to_critique\n[deep]
    planning --> researching : plan_to_research\n[quick || standard]

    %% critiquing_plan (carren, deep only) — bounded revise loop
    critiquing_plan --> researching : plan_critique_pass\n[verdict == APPROVE]
    critiquing_plan --> planning : plan_critique_revise\n[verdict != APPROVE && iter+1 < max_iterations]
    critiquing_plan --> researching : plan_critique_exhausted\n[budget spent; warning recorded]

    %% researching (echo DYNAMIC FAN: one branch per sub-query; single-agent on
    %% the explicit-quick fast-path). Fan-in aggregates by weakest confidence.
    researching --> synthesizing : research_done

    %% synthesizing (synthia) — deep adds a report critique gate; all modes then
    %% pass through the validation gate (phase guard routes a re-synthesis back
    %% to vera rather than re-running the critique)
    synthesizing --> critiquing_report : synth_to_critique\n[deep && phase != validation]
    synthesizing --> validating : synth_to_validate\n[quick || standard || phase == validation]

    %% critiquing_report (carren, deep only) — bounded revise loop → validation gate
    critiquing_report --> validating : report_critique_pass\n[verdict == APPROVE]
    critiquing_report --> synthesizing : report_critique_revise\n[verdict != APPROVE && iter+1 < max_iterations]
    critiquing_report --> validating : report_critique_exhausted\n[budget spent; warning recorded]

    %% validating (vera, ALL modes) — independent citation-grounding; bounded loop
    validating --> report_writing : validate_pass\n[verdict == PASS]
    validating --> synthesizing : validate_revise\n[verdict != PASS && iter+1 < max_iterations]
    validating --> report_writing : validate_exhausted\n[budget spent; warning recorded]

    %% report_writing (skribble) — write report.md / sources.md / README.md
    report_writing --> complete : report_done

    complete --> [*]
    error --> [*]

    %% ── Escalation seam (single HITL) — to_unknown from ESCALATABLE_STATES only ──
    planning --> unknown : to_unknown
    critiquing_plan --> unknown : to_unknown
    researching --> unknown : to_unknown
    synthesizing --> unknown : to_unknown
    critiquing_report --> unknown : to_unknown
    validating --> unknown : to_unknown
    unknown --> awaiting_clarification : escalate
    awaiting_clarification --> planning : clarify\n[user_response carried into task]

    %% ── Abort seam (any non-final state → error) ──
    intake --> error : abort
    planning --> error : abort
    critiquing_plan --> error : abort
    researching --> error : abort
    synthesizing --> error : abort
    critiquing_report --> error : abort
    validating --> error : abort
    report_writing --> error : abort
    unknown --> error : abort
    awaiting_clarification --> error : abort

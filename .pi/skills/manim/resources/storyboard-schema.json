{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "superpose/storyboard@1",
  "title": "Superpose storyboard",
  "type": "object",
  "required": ["video_id", "title", "theme", "scenes"],
  "properties": {
    "video_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"},
    "title": {"type": "string", "minLength": 1},
    "theme": {"type": "string"},
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["scene_id", "narration", "visuals"],
        "properties": {
          "scene_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"},
          "title": {"type": "string"},
          "narration": {"type": "string"},
          "visuals": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["primitive", "params", "beat"],
              "properties": {
                "primitive": {"type": "string"},
                "params": {"type": "object"},
                "beat": {"type": "integer", "minimum": 0},
                "duration": {"type": ["number", "null"], "minimum": 0}
              },
              "additionalProperties": false
            }
          },
          "duration_hint": {"type": ["number", "null"]},
          "measured_duration": {"type": ["number", "null"]},
          "depends_on": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

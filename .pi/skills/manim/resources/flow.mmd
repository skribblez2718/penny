    critiquing --> packaging: critique_pass
    critiquing --> packaging: critique_exhausted (met=False)
    packaging --> complete: package_done
    scoping --> unknown
    ingesting --> unknown
    designing_canon --> unknown
    storyboarding --> unknown
    authoring --> unknown
    verifying --> unknown
    fixing --> unknown

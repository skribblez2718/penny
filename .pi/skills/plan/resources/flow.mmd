%% ============================================================================
%% plan skill — FSM (engine playbook: PlanPlaybook / PlanMachine)
%% Source of truth: apps/orchestration/src/orchestration/playbooks/plan.py
%% Edge-for-edge accurate to PlanMachine. State lives in the durable SQLite
%% checkpointer keyed by run_id; escalation and the verify gate are engine seams.
%%
%% READING NOTES:
%%   * Guarded arrows out of one state are MUTUALLY EXCLUSIVE (exactly one fires).
%%   * scoping = piper: emits the exploration topology at runtime (arrangement 4).
%%     route_after turns explore_branches into ctx.extras["dynamic_branches"];
%%     the engine fans out one read-only echo branch per focus, bounded by
%%     constraints.max_fan_width (default 8). No fixed topology is baked in.
%%   * exploring = parallel echo fan-out (model-emitted branches, or the tagged
%%     LOAN default 3-branch topology when scoping emits none and the loan is on;
%%     ablated → scoping escalates instead).
%%   * planning = piper; critiquing = carren (independent evaluator, EVIDENCE-GATED
%%     — the contract rejects a verdict with no captured evidence, Rec 4).
%%   * revise loop is bounded by ctx.max_iterations (default 3); escalatable states
%%     route through to_unknown when progress_check returns a reason.
%% ============================================================================
stateDiagram-v2
    [*] --> intake

    %% Caller-supplied topology (constraints.explore_branches) skips scoping.
    intake --> scoping : start_scope
    intake --> exploring : start_explore\n[constraints.explore_branches]

    %% SCOPE (piper) emits the runtime fan topology, then exploration fans out.
    scoping --> exploring : scope_done\n[model-emitted topology → dynamic fan;\ndefault topology = tagged LOAN fallback]

    exploring --> planning : explore_done

    planning --> verify_gate : plan_to_verify\n[needs_verification: model-declared stakes]
    planning --> critiquing : plan_to_critique

    verify_gate --> critiquing : verify_confirm\n[user confirms]
    verify_gate --> planning : verify_revise\n[user revises]

    %% CRITIQUE (carren, evidence-gated). Pass taskifies; issues within budget
    %% loop back; exhaustion completes HONESTLY (met=False); BLOCKED halts;
    %% a stalled loop escalates.
    critiquing --> taskifying : critique_pass\n[APPROVE; evidence-gated]
    critiquing --> exploring : critique_retry_explore\n[NEEDS_REVISION, explore_rounds<2]
    critiquing --> planning : critique_retry_plan\n[NEEDS_REVISION, explore_rounds>=2]
    critiquing --> taskifying : critique_exhausted\n[budget spent; met=False]
    critiquing --> complete : critique_blocked\n[BLOCKED; halt, met=False]

    taskifying --> complete : taskify_done

    %% ESCALATION seam (HITL). clarify re-enters scoping (re-scope after answer).
    scoping --> unknown : to_unknown
    exploring --> unknown : to_unknown
    planning --> unknown : to_unknown
    critiquing --> unknown : to_unknown
    taskifying --> unknown : to_unknown
    unknown --> awaiting_clarification : escalate
    awaiting_clarification --> scoping : clarify\n[user response]

    %% ABORT (terminal error) is reachable from every non-terminal state.
    intake --> error : abort
    scoping --> error : abort
    exploring --> error : abort
    planning --> error : abort
    verify_gate --> error : abort
    critiquing --> error : abort
    taskifying --> error : abort
    unknown --> error : abort
    awaiting_clarification --> error : abort

    complete --> [*]
    error --> [*]

{
  "name": "@penny/playwright-extension",
  "version": "1.0.0",
  "description": "Playwright browser automation tools for Penny — native Pi extension",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "test": "bunx vitest run --config tests/vitest.config.ts",
    "test:unit": "bunx vitest run --config tests/vitest.config.ts",
    "test:integration": "bunx vitest run --config tests/vitest.integration.config.ts",
    "test:e2e": "bunx vitest run --config tests/vitest.e2e.config.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "test:all": "bun run lint && bun run format:check && bun run test:unit && bun run test:integration && bun run test:e2e"
  },
  "dependencies": {
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.0",
    "vitest": "^2.1.0",
    "@types/node": "^25.6.0"
  }
}

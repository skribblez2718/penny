# Secrets (never commit these)
*.pem
*.key
*.cert
secrets/
.secrets/

# Orchestration durable checkpointer (PENNY_ORCH_DB)
.penny/

# Generated documents (word/powerpoint extensions)
/output/

# Harness alignment audit reports (/audit) — local run artifacts, never committed
/audits/

# rez resume skill — committed for portability, but personal data stays LOCAL.
# The FSM reads resources/{resume,accomplishments}/ read-only, so those
# directories are committed (via their README placeholders) while the personal
# resume/accomplishment files inside them are never committed.
.pi/skills/rez/resources/resume/*
!.pi/skills/rez/resources/resume/README.md
.pi/skills/rez/resources/accomplishments/*
!.pi/skills/rez/resources/accomplishments/README.md
.pi/skills/rez/output/

# ===========================================
# Pi agent credentials & config (defensive)
# ===========================================
# OAuth tokens (auth.json) and machine-specific settings (settings.json) live in
# ~/.pi/agent/ OUTSIDE the repo. These rules ensure that if a copy ever lands
# in-tree it is never committed. auth.json is always a credential, so ignore it
# broadly; settings.json is scoped to the pi-agent context to avoid clobbering
# unrelated tools' settings.json (e.g. editors).
auth.json
**/auth.json
.pi/settings.json
.pi/agent/settings.json
**/agent/settings.json

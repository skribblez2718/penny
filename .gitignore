.ruff_cache/

# Pyre
.pyre/
.pyre_version/

# Pytype
.pytype/

# Cython debug
cython_debug/

# ===========================================
# Penny / MemPalace
# ===========================================

# Memory palace storage (user data) — live dir AND dated backup dirs
# (e.g. .mempalace.bak.2026-07-06/). These hold conversation/personal data.
.mempalace/
.mempalace.bak*/
.mempalace.bak*

# Entities file (generated)
entities.json

# Local working directories (design artifacts, research, plans)
/ideas/
/plans/
/research/


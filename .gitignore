# Penny AI Assistant - Git Ignore Configuration

# Ignore science directory
science/

# Ignore settings.json (contains user-specific configurations)
.claude/settings.json
.claude/settings.local.json

# Ignore memory directory contents (task-specific memory files)
.claude/memory/*

# Ignore plans directory contents (working plans and drafts)
.claude/plans/*

# Ignore reports directory contents (generated reports)
.claude/reports/*

# Ignore learnings directory contents
.claude/learnings/*

# Keep directory structure by not ignoring .gitkeep files
!.claude/memory/.gitkeep
!.claude/plans/.gitkeep
!.claude/reports/.gitkeep

# Node.js dependencies (if applicable)
node_modules/
package-lock.json
yarn.lock

# Python virtual environments (if applicable)
venv/
env/
.venv/
*.pyc
__pycache__/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/

# Environment variables
.env
.env.local
.env.*.local

# Temporary files
*.tmp
*.temp
.cache/

# ===========================================
# Penny Project .gitignore
# ===========================================

# Penny rule: NEVER write temporary files into the project tree.
# Runtime artifacts (downloads, dumps, caches, scratch state) belong in
# /tmp/ or user-configured locations outside the project.

# Skill extension checkpoint dir (runtime resume state)
.pi/skill-checkpoints/
**/.pi/skill-checkpoints/

# Environment & Secrets
.env
.env.*
!.env.example
.env.local
.env.*.local

# ===========================================
# Node.js / TypeScript
# ===========================================

node_modules/
dist/
build/
out/
*.tsbuildinfo

# Test coverage
coverage/
.nyc_output/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ===========================================
# Python
# ===========================================

# Virtual environment
.venv/
venv/
.venv-sca-tools/
env/
ENV/

# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Compiled extensions
*.so

# Distribution / packaging (root-anchored to protect .pi/lib/)
/build/
/develop-eggs/
/dist/
/downloads/
/eggs/
/.eggs/
/lib/
/lib64/
/parts/
/sdist/
/var/
/wheels/
/share/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.whl


# Penny Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# Required
# ===========================================

# Current project root
PROJECT_ROOT=/home/user/projects/penny

# Assistant name (displayed in status line)
DA_NAME=Penny

# ===========================================
# Pi / Agent Discovery
# ===========================================

# Canonical path to the .pi directory. Used as fallback by discoverAgents()
# when the cwd upward walk fails. The subagent extension appends /agents to
# this path automatically.
PI_DIRECTORY=/home/user/projects/penny/.pi

# Pi package directory (for documentation references)
PI_PACKAGE_DIR=/opt/pi/node_modules/@mariozechner/pi-coding-agent

# Directory where all projects are stored
PROJECTS_DIRECTORY=/home/user/projects

# ===========================================
# Search (Ollama API)
# ===========================================

# API key for web search via Ollama
# Get from: https://ollama.com/
OLLAMA_API_KEY=your-api-key-here

# ===========================================
# Observability
# ===========================================

# WebSocket server for real-time observability
PI_OBSERVABILITY_URL=ws://localhost:8765/ws

# REST API base URL (used by compaction extension)
PI_OBSERVABILITY_REST_URL=http://localhost:8765

# API key if required by your observability server
PI_OBSERVABILITY_API_KEY=

# Enable/disable observability (default: true)
PI_OBSERVABILITY_ENABLED=true

# Auto-start observability backend on session start (default: true)
PI_OBSERVABILITY_AUTO_START=true

# Max output length for tool results (default: 10000)
PI_OBSERVABILITY_MAX_OUTPUT_LENGTH=10000

# Data directory for SQLite DB
PI_OBSERVABILITY_DATA_DIR=/home/user/.local/share/penny/observability

# Retention: raw log entries (days, default: 14)
PI_OBSERVABILITY_RETENTION_RAW_DAYS=14

# Retention: log entries (days, default: 14)
PI_OBSERVABILITY_RETENTION_LOG_DAYS=14

# Retention: watcher log entries (days, default: 90)
PI_OBSERVABILITY_RETENTION_WATCHER_LOG_DAYS=90

# Retention: compaction artifacts (days, default: 90)
PI_OBSERVABILITY_RETENTION_COMPACTION_DAYS=90

# Observability server host (default: localhost)
# PI_OBSERVABILITY_HOST=localhost

# Observability server port (default: 8765)
# PI_OBSERVABILITY_PORT=8765

# Max SQLite DB size in GB (default: 1)
# PI_OBSERVABILITY_DB_SIZE_MAX_GB=1

# ===========================================
# Memory System (MemPalace)
# ===========================================

# Path to the Python virtual environment
PI_VENV_PYTHON=/home/user/projects/penny/.venv/bin/python

# Path to the memory bridge script
PI_MEMORY_BRIDGE=/home/user/projects/penny/scripts/system/bridge/memory_bridge.py

# MemPalace uses ChromaDB and SQLite locally — no API keys needed.
# Override default palace path (optional, defaults to ~/.mempalace/palace)
# MEMPALACE_PATH=/home/user/.mempalace

# ===========================================
# Skill Configuration
# ===========================================

# Skill timeout in milliseconds (default: 43200000 = 12 hours)
# PENNY_SKILL_TIMEOUT=43200000

# Agent timeout in milliseconds (default: 1800000 = 30 minutes)
# PENNY_AGENT_TIMEOUT=1800000

# Max skill iterations before error (default: 20)
# PENNY_SKILL_MAX_ITERATIONS=20

# Override skills directory (default: .pi/skills)
# PENNY_SKILLS_DIR=/home/user/projects/penny/.pi/skills

# ===========================================
# Playwright (Browser Automation)
# ===========================================

# Proxy server for Playwright browser traffic (e.g., http://localhost:8080)
# PLAYWRIGHT_PROXY_SERVER=http://localhost:8080

# Proxy bypass list (comma-separated hosts)
# PLAYWRIGHT_PROXY_BYPASS=localhost,127.0.0.1

# Ignore HTTPS errors (default: false)
# PLAYWRIGHT_IGNORE_HTTPS_ERRORS=false

# Headless mode (default: true)
# PLAYWRIGHT_HEADLESS=true

# ===========================================
# External Tools
# ===========================================

# Path to nuclei templates (used by jsa skill)
# NUCLEI_TEMPLATES_PATH=/home/user/tool_resources/nuclei-templates

# ===========================================
# Caido (HTTP Proxy / Replay)
# ===========================================

# Caido API URL (default: http://localhost:8080)
# CAIDO_URL=http://localhost:8080

# Caido personal access token (generate from Caido Settings → Access Tokens)
# CAIDO_PAT=your-caido-pat-here

# ===========================================
# Structured Error Logging
# ===========================================

# Log verbosity level (DEBUG | INFO | WARN | ERROR | CRITICAL)
# default: WARN
PI_LOG_LEVEL=WARN

# Log output format (json | text)
# json = structured JSON lines to stderr
# text = human-readable bracketed format
# default: json
PI_LOG_FORMAT=json

[flake8]
max-line-length = 100
max-complexity = 10
extend-ignore = E203, E501, W503, W504
exclude =
    .git,
    .hg,
    .megg,
    .mypy_cache,
    .tox,
    .venv,
    _build,
    buck-out,
    build,
    dist,
    node_modules,
    __pycache__,
    *.egg-info,
per-file-ignores =
    __init__.py: F401
    *.test.py: F401,F811